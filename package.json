{
  "name": "atlassian-dc-mcp",
  "version": "0.1.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/b1ff/atlassian-dc-mcp.git"
  },
  "homepage": "https://github.com/b1ff/atlassian-dc-mcp#readme",
  "bugs": {
    "url": "https://github.com/b1ff/atlassian-dc-mcp/issues"
  },
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspace=@atlassian-dc-mcp/common && npm run build --workspaces",
    "test": "npm run test --workspaces",
    "dev:jira": "npm run dev --workspace=@atlassian-dc-mcp/jira",
    "dev:confluence": "npm run dev --workspace=@atlassian-dc-mcp/confluence",
    "dev:bitbucket": "npm run dev --workspace=@atlassian-dc-mcp/bitbucket",
    "debug": "node mcp-live-debug.js",
    "debug:verbose": "node mcp-live-debug.js --verbose",
    "debug:ts": "nodemon --exec ts-node --esm",
    "publish:ci": "lerna version --conventional-commits --yes --no-push && lerna publish from-package --yes",
    "lerna": "lerna"
  },
  "overrides": {
    "tar": "^7.5.11"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "jest": "^30.1.3",
    "lerna": "^9.0.5",
    "nodemon": "^3.1.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  }
}
